#!/bin/bash

#===============================================================================
# MATRIX CBS - Deploy Konfiguracio
#
# FONTOS: Masold config.sh neven es toltsd ki a valos adatokkal!
# A config.sh TILOS VERZIOKEZELESBE KERULNI!
#
# SSH kulcs beallitasa:
#   1. Generalj SSH kulcsot: ssh-keygen -t ed25519 -C "deploy@matrixcbs"
#   2. Masold a publikus kulcsot a szerverre: ssh-copy-id -p <SSH_PORT> <SSH_USER>@<SZERVER_HOST>
#   3. Vagy add hozza a ~/.ssh/authorized_keys-hez a szerveren
#===============================================================================

# SSH kapcsolat (kulcs alapu!)
SSH_HOST="<SZERVER_HOST>"
SSH_PORT="<SSH_PORT>"
SSH_USER="<SSH_USER>"
# Nincs jelszo - SSH kulcsot hasznalj!

# Szerver utvonalak
REMOTE_BASE="<REMOTE_BASE_PATH>"
REMOTE_TMP="$REMOTE_BASE/tmp"
REMOTE_WEB="$REMOTE_BASE/web"
REMOTE_PRIVATE="$REMOTE_BASE/private"

# ISPConfig felhasznalo/csoport
WEB_USER="<WEB_USER>"
WEB_GROUP="<WEB_GROUP>"

#===============================================================================
# Adatbazis beallitasok
#===============================================================================

# Lokalis adatbazis (Docker)
LOCAL_DB_NAME="matrixcbs"
LOCAL_DB_USER="matrixcbs"
LOCAL_DB_PASS="matrixcbs_password"
LOCAL_DB_HOST="localhost"
LOCAL_DB_PORT="3306"
LOCAL_DB_CONTAINER="matrixcbs-db"  # Docker container neve

# Eles adatbazis
REMOTE_DB_NAME="<REMOTE_DB_NAME>"
REMOTE_DB_USER="<REMOTE_DB_USER>"
REMOTE_DB_PASS="<ADATBAZIS_JELSZO_IDE>"
REMOTE_DB_HOST="localhost"
