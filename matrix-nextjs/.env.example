# MATRIX CBS - Environment Variables Template
# Copy this file to .env and fill in the actual values

# Database Connection
# FONTOS: A charset=utf8mb4 paraméter kötelező a magyar ékezetes karakterek helyes kezeléséhez!
DATABASE_URL="mysql://user:password@localhost:3306/database_name?charset=utf8mb4"

# Cron Job Authentication
# Generate a secure random secret: openssl rand -base64 32
CRON_SECRET="your-secure-random-secret-here"

# Next.js Configuration
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Session/Auth Configuration (if applicable)
# NEXTAUTH_SECRET="another-secure-random-secret"
# NEXTAUTH_URL="http://localhost:3000"
